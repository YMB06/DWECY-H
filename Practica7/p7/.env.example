# API Endpoint de Beeceptor (crea tu endpoint gratuito en https://beeceptor.com)
VITE_API_BASE_URL=https://your-endpoint.free.beeceptor.com

# ============================================================
# EJERCICIO 2: AI-UML Architect - Generador de Diagramas con IA
# ============================================================
# API Key de OpenAI (obtén en https://platform.openai.com/api-keys)
VITE_OPENAI_API_KEY=sk-...

# ============================================================
# EJERCICIO 3: SpriteSheet AI Forge - Generador y Animador de Sprites
# ============================================================
# API Key de Hugging Face (obtén en https://huggingface.co/settings/tokens)
VITE_HUGGINGFACE_API_KEY=hf_...

# ============================================================
# EJERCICIO 4: GitHub DevHub - Panel Seguro
# ============================================================
# Credenciales de Firebase (obtén en Firebase Console)
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=yourproject.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=yourproject
VITE_FIREBASE_STORAGE_BUCKET=yourproject.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:...

# ============================================================
# Configuración General
# ============================================================
# Ambiente de la aplicación (development | production)
VITE_APP_ENV=production

